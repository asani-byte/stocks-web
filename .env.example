# Copy this file to .env.local and fill in your real keys.
# .env.local is gitignored — never commit real API keys.

# --- Price data provider ---
# Choose "finnhub" or "polygon"
PRICE_PROVIDER=finnhub

# Finnhub: https://finnhub.io/dashboard  (free tier available)
FINNHUB_API_KEY=your_finnhub_key_here

# Polygon.io: https://polygon.io/dashboard/api-keys  (only needed if PRICE_PROVIDER=polygon)
POLYGON_API_KEY=your_polygon_key_here

# --- News provider ---
# NewsAPI: https://newsapi.org/register  (free tier available, dev use only)
NEWSAPI_API_KEY=your_newsapi_key_here
